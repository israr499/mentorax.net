@{
    ViewData["Title"] = "Test Chat";
    var userId = Context.Session.GetString("UserId");
    var userName = Context.Session.GetString("UserFullName");
    var userRole = Context.Session.GetString("UserRole");
}

<h2>Test Chat - @userRole</h2>
<p><strong>Your User ID:</strong> <code id="myUserId">@userId</code></p>
<p><strong>Your Name:</strong> @userName</p>

<hr />

<div>
    <label>Other User's ID:</label>
    <input type="text" id="otherUserId" class="form-control" style="width: 400px;" placeholder="Paste the other user's ID here" />
    <button class="btn btn-primary mt-2" onclick="createRoom()">Create / Open Chat Room</button>
</div>

<div id="chatPanel" style="display: none; margin-top: 20px;">
    <div class="card">
        <div class="card-header bg-info text-white">
            <strong>Chat Room</strong>
        </div>
        <div class="card-body">
            <div id="messagesList" style="height: 300px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; background: #f9f9f9;">
                <em class="text-muted">No messages yet...</em>
            </div>
            <div class="mt-3">
                <input type="text" id="messageInput" class="form-control" placeholder="Type your message..." />
                <button class="btn btn-success mt-2" onclick="sendMessage()">Send Message</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    let connection = null;
    let currentRoomId = null;
    let currentReceiverId = null;
    let currentUserId = '@userId';
    let currentUserName = '@userName';

    async function createRoom() {
        const otherUserId = document.getElementById("otherUserId").value.trim();
        if (!otherUserId) {
            alert("Please enter the other user's ID");
            return;
        }
        currentReceiverId = otherUserId;

        console.log("Creating room between", currentUserId, "and", otherUserId);

        try {
            const response = await fetch(`https://mentorax-chat-gabwajbratc0d0f4.southeastasia-01.azurewebsites.net/api/Chat/GetOrCreateRoom?studentId=${currentUserId}&tutorId=${otherUserId}`);
            const room = await response.json();
            currentRoomId = room.roomID;
            console.log("Room ID:", currentRoomId);

            // Initialize SignalR connection
            connection = new signalR.HubConnectionBuilder()
                .withUrl(`https://mentorax-chat-gabwajbratc0d0f4.southeastasia-01.azurewebsites.net/chathub?userId=${currentUserId}`)
                .configureLogging(signalR.LogLevel.Information)
                .build();

            // Handle incoming messages
            connection.on("ReceiveMessage", (roomId, message, senderName, time, senderId) => {
                console.log("Message received:", message, "from", senderName);
                const messagesDiv = document.getElementById("messagesList");
                const timeStr = new Date(time).toLocaleTimeString();
                const isMine = senderId === currentUserId;
                messagesDiv.innerHTML += `
                    <div style="text-align: ${isMine ? 'right' : 'left'}; margin-bottom: 10px;">
                        <strong>${senderName}:</strong> ${message}
                        <br/><small class="text-muted">${timeStr}</small>
                    </div>
                `;
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            });

            await connection.start();
            console.log("SignalR connected!");

            await connection.invoke("JoinRoom", currentRoomId);
            console.log("Joined room:", currentRoomId);

            // Load existing messages
            const msgResponse = await fetch(`https://mentorax-chat-gabwajbratc0d0f4.southeastasia-01.azurewebsites.net/api/Chat/GetMessages/${currentRoomId}`);
            const messages = await msgResponse.json();
            const messagesDiv = document.getElementById("messagesList");
            messagesDiv.innerHTML = '';
            for (const msg of messages) {
                const isMine = msg.senderID === currentUserId;
                const senderName = isMine ? "You" : (msg.senderID === currentReceiverId ? "Other" : "Unknown");
                const timeStr = new Date(msg.sentAt).toLocaleTimeString();
                messagesDiv.innerHTML += `
                    <div style="text-align: ${isMine ? 'right' : 'left'}; margin-bottom: 10px;">
                        <strong>${senderName}:</strong> ${msg.message}
                        <br/><small class="text-muted">${timeStr}</small>
                    </div>
                `;
            }
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            document.getElementById("chatPanel").style.display = "block";
            document.getElementById("messageInput").focus();

        } catch (err) {
            console.error("Error:", err);
            alert("Failed to create chat: " + err.message);
        }
    }

    async function sendMessage() {
        const message = document.getElementById("messageInput").value.trim();
        if (!message) return;
        if (!connection || connection.state !== "Connected") {
            alert("Not connected. Please create room again.");
            return;
        }

        try {
            await connection.invoke("SendMessage", currentRoomId, message, currentUserId, currentReceiverId, currentUserName);
            document.getElementById("messageInput").value = '';
            // Message will appear via ReceiveMessage handler
        } catch (err) {
            console.error("Send error:", err);
            alert("Failed to send: " + err.message);
        }
    }
</script>