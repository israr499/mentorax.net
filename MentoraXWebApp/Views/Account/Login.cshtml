@model MentoraXWebApp.Models.LoginViewModel

@{
    ViewData["Title"] = "Login - MentoraX";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --brand-from: #667eea;
            --brand-to: #764ba2;
        }

        body {
            background: linear-gradient(135deg, var(--brand-from) 0%, var(--brand-to) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Subtle animated blobs behind the card */
        .blob {
            position: fixed;
            border-radius: 50%;
            opacity: .18;
            filter: blur(80px);
            pointer-events: none;
            animation: drift 14s ease-in-out infinite alternate;
        }

        .blob-1 {
            width: 380px;
            height: 380px;
            background: #a78bfa;
            top: -80px;
            left: -120px;
            animation-delay: 0s;
        }

        .blob-2 {
            width: 320px;
            height: 320px;
            background: #38bdf8;
            bottom: -60px;
            right: -100px;
            animation-delay: 4s;
        }
       
        keyframes drift {
            from

        {
            transform: translate(0,0)
        }

        to {
            transform: translate(30px,40px)
        }

        }

        .login-card {
            border-radius: 22px;
            box-shadow: 0 24px 60px rgba(0,0,0,.18);
            overflow: hidden;
            max-width: 460px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        .login-header {
            background: linear-gradient(135deg, var(--brand-from) 0%, var(--brand-to) 100%);
            color: white;
            padding: 36px 32px;
            text-align: center;
        }

        .logo-ring {
            width: 72px;
            height: 72px;
            background: rgba(255,255,255,.18);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin-bottom: 14px;
            border: 2px solid rgba(255,255,255,.35);
        }

        .login-body {
            background: white;
            padding: 38px 40px;
        }

        .form-control {
            border-radius: 10px;
            padding: 11px 14px;
            border: 1.5px solid #e0e0e0;
            font-size: 15px;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-control:focus {
                border-color: var(--brand-from);
                box-shadow: 0 0 0 3px rgba(102,126,234,.15);
            }

        .input-group-text {
            background: #f8f7ff;
            border: 1.5px solid #e0e0e0;
            border-right: none;
            color: var(--brand-from);
            border-radius: 10px 0 0 10px;
        }

        .input-group .form-control {
            border-left: none;
            border-radius: 0 10px 10px 0;
        }

        .input-group:focus-within .input-group-text {
            border-color: var(--brand-from);
        }

        .btn-login {
            background: linear-gradient(135deg, var(--brand-from) 0%, var(--brand-to) 100%);
            border: none;
            padding: 13px;
            font-size: 16px;
            font-weight: 700;
            border-radius: 12px;
            letter-spacing: .4px;
            transition: opacity .2s, transform .1s;
        }

            .btn-login:hover {
                opacity: .92;
                transform: translateY(-1px);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .divider {
            position: relative;
            text-align: center;
            margin: 20px 0;
        }

            .divider::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                height: 1px;
                background: #eee;
            }

            .divider span {
                position: relative;
                background: white;
                padding: 0 12px;
                color: #aaa;
                font-size: 13px;
            }

        .btn-register-student {
            border: 2px solid var(--brand-from);
            color: var(--brand-from);
            border-radius: 10px;
            font-weight: 600;
            padding: 9px;
            transition: all .2s;
        }

            .btn-register-student:hover {
                background: var(--brand-from);
                color: white;
            }

        .btn-register-tutor {
            border: 2px solid #198754;
            color: #198754;
            border-radius: 10px;
            font-weight: 600;
            padding: 9px;
            transition: all .2s;
        }

            .btn-register-tutor:hover {
                background: #198754;
                color: white;
            }

        /* Password toggle icon */
        .pw-toggle {
            cursor: pointer;
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            z-index: 5;
        }

            .pw-toggle:hover {
                color: var(--brand-from);
            }

        .alert {
            border-radius: 10px;
            font-size: 14px;
        }

        .spinner-border {
            width: 1rem;
            height: 1rem;
            border-width: 2px;
        }
    </style>
</head>
<body>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="container px-3">
        <div class="login-card mx-auto">

            <!-- Header -->
            <div class="login-header">
                <div class="logo-ring">
                    <i class="fas fa-chalkboard-user"></i>
                </div>
                <h2 class="fw-bold mb-1">Welcome to MentoraX</h2>
                <p class="mb-0 opacity-85">Your Learning Journey Continues Here</p>
            </div>

            <!-- Body -->
            <div class="login-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                        <i class="fas fa-circle-exclamation"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                        <i class="fas fa-circle-exclamation"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <form asp-action="Login" method="post" id="login-form" novalidate>
                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-secondary small">
                            Email Address
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-envelope fa-sm"></i>
                            </span>
                            <input asp-for="Email" class="form-control"
                                   type="email" placeholder="you@example.com"
                                   autocomplete="email" required />
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary small">
                            Password
                        </label>
                        <div class="input-group position-relative">
                            <span class="input-group-text">
                                <i class="fas fa-lock fa-sm"></i>
                            </span>
                            <input asp-for="Password" class="form-control pe-5"
                                   type="password" placeholder="••••••••"
                                   id="passwordField" autocomplete="current-password" required />
                            <i class="fas fa-eye pw-toggle" id="pw-toggle" title="Show password"></i>
                        </div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-primary btn-login w-100" id="login-btn">
                        <span id="btn-text">
                            <i class="fas fa-sign-in-alt me-2"></i>Sign In
                        </span>
                        <span id="btn-loading" class="d-none">
                            <span class="spinner-border me-2" role="status"></span>
                            Signing in…
                        </span>
                    </button>
                </form>

                <div class="divider"><span>New to MentoraX?</span></div>

                <div class="row g-2">
                    <div class="col-6">
                        <a asp-action="RegisterStudent"
                           class="btn btn-register-student w-100 text-center text-decoration-none">
                            <i class="fas fa-user-graduate me-1"></i>
                            Join as Student
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="RegisterTutor"
                           class="btn btn-register-tutor w-100 text-center text-decoration-none">
                            <i class="fas fa-chalkboard me-1"></i>
                            Join as Tutor
                        </a>
                    </div>
                </div>

            </div><!-- /login-body -->
        </div><!-- /login-card -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Password visibility toggle
        document.getElementById('pw-toggle').addEventListener('click', function () {
            const field = document.getElementById('passwordField');
            const isHidden = field.type === 'password';
            field.type = isHidden ? 'text' : 'password';
            this.classList.toggle('fa-eye',      !isHidden);
            this.classList.toggle('fa-eye-slash', isHidden);
        });

        // Loading spinner on submit
        document.getElementById('login-form').addEventListener('submit', function () {
            document.getElementById('btn-text').classList.add('d-none');
            document.getElementById('btn-loading').classList.remove('d-none');
            document.getElementById('login-btn').disabled = true;
        });
    </script>
</body>
</html>
