@model List<MentoraXWebApp.Models.Booking>

@{
    ViewData["Title"] = "Tutor Dashboard";
    var tutor = ViewBag.Tutor as MentoraXWebApp.Models.TutorProfile;
}

<div class="container mt-4">
    <div class="row g-4">

        <!-- ── Sidebar ─────────────────────────────────────────── -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center" style="border-radius:16px">
                <div class="card-body pt-4 pb-3">
                    @if (!string.IsNullOrEmpty(tutor?.ProfileImageUrl))
                    {
                        <img src="@tutor.ProfileImageUrl" class="rounded-circle mb-3 shadow"
                             width="90" height="90" style="object-fit:cover" />
                    }
                    else
                    {
                        <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                             style="width:90px;height:90px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:36px;color:#fff;font-weight:700">
                            @(tutor?.FullName?.Length > 0 ? tutor.FullName[0].ToString().ToUpper() : "T")
                        </div>
                    }
                    <h5 class="fw-bold mb-1">@tutor?.FullName</h5>
                    <p class="text-muted small mb-2">@tutor?.Specialization</p>

                    @if (tutor?.Status == "Approved")
                    {
                        <span class="badge bg-success rounded-pill px-3 mb-2">✓ Approved</span>
                    }
                    else if (tutor?.Status == "Pending")
                    {
                        <span class="badge bg-warning text-dark rounded-pill px-3 mb-2">⏳ Pending</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3 mb-2">✗ Rejected</span>
                    }

                    <hr class="my-2" />
                    <div class="text-start small px-2">
                        <div class="mb-1"><i class="fas fa-tag text-primary me-2"></i><strong>$@tutor?.HourlyRate</strong>/hr</div>
                        <div class="mb-1"><i class="fas fa-briefcase text-primary me-2"></i>@tutor?.ExperienceYears yrs exp</div>
                    </div>
                    <a asp-action="CompleteProfile" class="btn btn-outline-primary btn-sm w-100 rounded-pill mt-3">
                        <i class="fas fa-edit me-1"></i>Edit Profile
                    </a>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(tutor?.IntroVideoUrl))
            {
                <div class="card border-0 shadow-sm mt-3" style="border-radius:16px">
                    <div class="card-body p-3 text-center">
                        <a href="@tutor.IntroVideoUrl" target="_blank" class="btn btn-outline-danger btn-sm w-100 rounded-pill">
                            <i class="fab fa-youtube me-1"></i>Intro Video
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- ── Main ───────────────────────────────────────────── -->
        <div class="col-md-9">

            <!-- Revenue Section -->
            <div id="revenueSection" class="card border-0 shadow-sm mb-4" style="border-radius:16px">
                <div class="card-header border-0 fw-semibold text-white rounded-top-3"
                     style="background:linear-gradient(135deg,#0078d4,#2b88d8)">
                    <i class="fas fa-chart-line me-2"></i>My Revenue
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6 col-lg-4">
                            <div class="revenue-card">
                                <h3><i class="fas fa-wallet me-1"></i>Total Earned</h3>
                                <p class="amount" id="rev-earned"><i class="fas fa-circle-notch fa-spin"></i></p>
                                <small style="opacity:.8">Your 70% share</small>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="revenue-card" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                                <h3><i class="fas fa-dollar-sign me-1"></i>Gross Revenue</h3>
                                <p class="amount" id="rev-gross">—</p>
                                <small style="opacity:.8">Total before fees</small>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="revenue-card" style="background:linear-gradient(135deg,#764ba2,#667eea)">
                                <h3><i class="fas fa-building me-1"></i>Platform Fee</h3>
                                <p class="amount" id="rev-fee">—</p>
                                <small style="opacity:.8">30% platform share</small>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-6">
                            <div class="card border-0 bg-light text-center py-3" style="border-radius:12px">
                                <div class="h2 fw-bold text-primary mb-0" id="rev-bookings">—</div>
                                <div class="text-muted small">Completed Bookings</div>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-6">
                            <div class="card border-0 bg-light text-center py-3" style="border-radius:12px">
                                <div class="h2 fw-bold text-success mb-0" id="rev-hours">—</div>
                                <div class="text-muted small">Hours Taught</div>
                            </div>
                        </div>
                    </div>

                    <!-- Monthly Chart -->
                    <div class="chart-container" style="height:220px;position:relative">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Bookings Card -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius:16px">
                <div class="card-header border-0 fw-semibold text-white rounded-top-3"
                     style="background:linear-gradient(135deg,#667eea,#764ba2)">
                    <i class="fas fa-calendar-check me-2"></i>My Bookings
                </div>
                <div class="card-body p-0">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Student</th>
                                        <th>Topic</th>
                                        <th>Date & Time</th>
                                        <th>Dur.</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@booking.StudentName</td>
                                            <td>@booking.Topic</td>
                                            <td class="small text-muted">@booking.BookingDate.ToString("MMM dd, yyyy HH:mm")</td>
                                            <td>@booking.DurationHours h</td>
                                            <td class="text-success fw-semibold">$@booking.TotalAmount</td>
                                            <td>
                                                @if (booking.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                }
                                                else if (booking.Status == "Confirmed")
                                                {
                                                    <span class="badge bg-success">Confirmed</span>
                                                }
                                                else if (booking.Status == "Completed")
                                                {
                                                    <span class="badge bg-info">Completed</span>
                                                }
                                                else if (booking.Status == "Cancelled")
                                                {
                                                    <span class="badge bg-danger">Cancelled</span>
                                                }
                                            </td>
                                            <td>
                                                @if (booking.Status == "Pending")
                                                {
                                                    <form asp-action="ConfirmBooking" method="post" style="display:inline">
                                                        <input type="hidden" name="bookingId" value="@booking.BookingID" />
                                                        <button type="submit" class="btn btn-success btn-sm rounded-pill">
                                                            <i class="fas fa-check me-1"></i>Confirm
                                                        </button>
                                                    </form>
                                                }
                                                @if (booking.Status == "Confirmed")
                                                {
                                                    <form asp-action="CompleteBooking" method="post" style="display:inline">
                                                        <input type="hidden" name="bookingId" value="@booking.BookingID" />
                                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill">
                                                            <i class="fas fa-flag-checkered me-1"></i>Complete
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-times fa-3x mb-3 d-block" style="opacity:.3"></i>
                            <p>No bookings yet. Your upcoming sessions will appear here.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Conversations Card -->
            <div class="card border-0 shadow-sm" style="border-radius:16px">
                <div class="card-header border-0 fw-semibold text-white rounded-top-3"
                     style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                    <i class="fas fa-comments me-2"></i>Your Conversations
                </div>
                <div class="card-body p-0">
                    <div id="chatRoomsList">
                        <div class="text-center p-4 text-muted">
                            <i class="fas fa-circle-notch fa-spin me-2"></i>Loading conversations…
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // FIX: Do NOT call initChat here.
    // _Layout.cshtml already calls initChat on DOMContentLoaded.
    // Calling it a second time opens a duplicate SignalR connection
    // which causes every message to appear twice.

    document.addEventListener('DOMContentLoaded', function () {
        var tutorUserId = '@Context.Session.GetString("UserId")';
        console.log('[Dashboard] Loading rooms for userId:', tutorUserId);

        // Delay slightly so initChat (from _Layout) has time to connect first
        setTimeout(function () {
            loadTutorRooms(tutorUserId);
        }, 800);
    });

    function loadTutorRooms(tutorUserId) {
        if (!tutorUserId) return;

        fetch('https://mentorax-chat-gabwajbratc0d0f4.southeastasia-01.azurewebsites.net/api/Chat/GetUserRooms/' + tutorUserId)
            .then(function (res) {
                if (!res.ok) throw new Error('HTTP ' + res.status);
                return res.json();
            })
            .then(function (rooms) {
                var container = document.getElementById('chatRoomsList');
                if (!container) return;

                if (!rooms || rooms.length === 0) {
                    container.innerHTML = '<div class="text-center p-4 text-muted"><i class="fas fa-comment-slash me-2"></i>No conversations yet.</div>';
                    return;
                }

                var html = '';
                for (var i = 0; i < rooms.length; i++) {
                    var room = rooms[i];

                    // Support both camelCase and PascalCase
                    var roomId    = room.roomID    || room.RoomID    || '';
                    var studentId = room.studentID || room.StudentID || '';
                    var tutorId   = room.tutorID   || room.TutorID   || '';
                    var unread    = room.unreadCount != null ? room.unreadCount : (room.UnreadCount || 0);

                    // ── FIX: CORRECT ROLE DISPLAY ──────────────────────────
                    // Current user is the Tutor.
                    // If current userId === studentID → impossible on tutor dashboard,
                    //   but we check anyway for safety.
                    // If current userId === tutorID → correct → show "Student"
                    var isCurrentUserTutor = (tutorId === tutorUserId);
                    // If they're the tutor in this room, the other person is the Student.
                    // If somehow they're the student (edge case), the other person is the Tutor.
                    var otherLabel = isCurrentUserTutor ? 'Student' : 'Tutor';
                    var otherId    = isCurrentUserTutor ? studentId : tutorId;

                    var unreadBadge = unread > 0
                        ? ' <span class="badge bg-danger rounded-pill ms-1">' + unread + '</span>'
                        : '';

                    html += '<div class="chat-room-item d-flex align-items-center gap-2 p-3 border-bottom"' +
                            ' data-room="' + roomId + '"' +
                            ' data-other-id="' + otherId + '"' +
                            ' data-other-name="' + otherLabel + '"' +
                            ' style="cursor:pointer;transition:background .15s;"' +
                            ' onmouseover="this.style.background=\'#f5f3ff\'"' +
                            ' onmouseout="this.style.background=\'\'">' +
                            '<div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"' +
                            ' style="width:38px;height:38px;background:linear-gradient(135deg,#11998e,#38ef7d);color:#fff;font-weight:700;font-size:16px">' +
                            otherLabel[0] +
                            '</div>' +
                            '<div class="flex-grow-1">' +
                            '<div class="fw-semibold" style="font-size:14px">Chat with ' + otherLabel + unreadBadge + '</div>' +
                            '<div class="text-muted" style="font-size:12px">Click to open conversation</div>' +
                            '</div>' +
                            '<i class="fas fa-chevron-right text-muted" style="font-size:12px"></i>' +
                            '</div>';
                }

                container.innerHTML = html;

                // Attach click handlers
                var items = container.querySelectorAll('.chat-room-item');
                for (var j = 0; j < items.length; j++) {
                    (function (el) {
                        el.addEventListener('click', function () {
                            var rId   = el.getAttribute('data-room');
                            var oName = el.getAttribute('data-other-name');
                            var oId   = el.getAttribute('data-other-id');
                            console.log('[Dashboard] Opening room:', rId, oName, oId);
                            if (typeof window.openRoom === 'function') {
                                window.openRoom(rId, oName, oId);
                            } else {
                                console.error('[Dashboard] window.openRoom not found — is chat.js loaded?');
                            }
                        });
                    })(items[j]);
                }
            })
            .catch(function (err) {
                console.error('[Dashboard] loadTutorRooms error:', err);
                var container = document.getElementById('chatRoomsList');
                if (container) {
                    container.innerHTML = '<div class="text-center p-4 text-danger"><i class="fas fa-exclamation-circle me-2"></i>Could not load conversations.</div>';
                }
            });
    }
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/revenue.js"></script>
    <script src="~/js/validations.js"></script>
}
