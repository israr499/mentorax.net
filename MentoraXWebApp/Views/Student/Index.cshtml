@model List<MentoraXWebApp.Models.TutorProfile>

@{
    ViewData["Title"] = "Find a Tutor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Hero Search -->
    <div class="hero-band">
        <h1 class="fw-bold mb-1"><i class="fas fa-search me-2"></i>Find Your Tutor</h1>
        <p class="mb-3 opacity-75">Search from our library of approved tutors</p>
        <form method="get" asp-action="Index">
            <div class="input-group input-group-lg" style="max-width:500px">
                <span class="input-group-text bg-white border-0"><i class="fas fa-book text-primary"></i></span>
                <input type="text" name="searchSubject" class="form-control border-0 shadow-none"
                       placeholder="e.g. Mathematics, Physics, English…" value="@ViewBag.SearchSubject" />
                <button type="submit" class="btn btn-warning fw-semibold px-4">Search</button>
            </div>
        </form>
    </div>

    <!-- Conversations Panel -->
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header text-white fw-semibold"
             style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%)">
            <i class="fas fa-comments me-2"></i>Your Conversations
        </div>
        <div class="card-body p-0">
            <div id="chatRoomsList">
                <div class="loading-state"><i class="fas fa-circle-notch fa-spin"></i><p class="mt-2">Loading…</p></div>
            </div>
        </div>
    </div>

    <!-- Tutor Grid -->
    @if (Model != null && Model.Any())
    {
        <h4 class="mb-3 text-muted">
            <i class="fas fa-chalkboard-teacher me-1"></i>
            @Model.Count Tutor@(Model.Count != 1 ? "s" : "") Available
        </h4>
        <div class="row g-4">
            @foreach (var tutor in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm border-0 tutor-card" style="border-radius:14px;transition:transform .2s,box-shadow .2s">
                        <div class="card-body text-center pt-4">
                            <div class="mb-3 mx-auto d-flex align-items-center justify-content-center rounded-circle"
                                 style="width:70px;height:70px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:28px;color:#fff;font-weight:700">
                                @(tutor.FullName?.Length > 0 ? tutor.FullName[0].ToString().ToUpper() : "T")
                            </div>
                            <h5 class="fw-bold mb-0">@tutor.FullName</h5>
                            <p class="text-muted small mb-2">@tutor.Specialization</p>
                            <div class="d-flex justify-content-center gap-3 mb-3 small">
                                <span><i class="fas fa-briefcase text-primary me-1"></i>@tutor.ExperienceYears yrs</span>
                                <span><i class="fas fa-dollar-sign text-success me-1"></i>@tutor.HourlyRate/hr</span>
                                <span><i class="fas fa-star text-warning me-1"></i>@tutor.TotalReviews reviews</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3 px-3">
                            <a href="/Student/TutorDetails/@tutor.TutorID" class="btn btn-primary w-100 rounded-pill">
                                <i class="fas fa-user me-1"></i>View Profile
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-4x text-muted mb-3 d-block" style="opacity:.3"></i>
            <h4 class="text-muted">No tutors found</h4>
            <p class="text-muted">Try a different subject or clear the search.</p>
            <a asp-action="Index" class="btn btn-outline-primary">Show All Tutors</a>
        </div>
    }
</div>

<style>
    .tutor-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,0,0,.12) !important;
    }
</style>

@section Scripts {
    <script>
        // Chat is initialised once by _Layout.cshtml DOMContentLoaded handler.
        // We just refresh the rooms list after the connection is ready.
        setTimeout(function () {
            if (typeof loadChatRooms === 'function') loadChatRooms();
        }, 1500);
    </script>
}
