@{
    ViewData["Title"] = "Tutor Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="@Url.Action("AllUsers", "Admin")" class="btn btn-outline-secondary rounded-pill px-3">
        <i class="fas fa-arrow-left me-2"></i>Back to Users
    </a>
</div>

<div class="text-center py-5">
    <div class="mb-4" style="font-size:64px;opacity:.3">
        <i class="fas fa-user-slash"></i>
    </div>
    <h3 class="fw-bold text-muted mb-2">Tutor Profile Not Found</h3>
    <p class="text-muted mb-4">
        @(ViewBag.ErrorMessage ?? "This user has not completed their tutor profile yet.")
    </p>
    <a href="@Url.Action("AllUsers", "Admin")" class="btn btn-primary rounded-pill px-4">
        <i class="fas fa-users me-2"></i>Return to User Management
    </a>
</div>
